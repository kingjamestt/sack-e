rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    function isOrganizer(eventId) {
      return isAuthenticated() && get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid;
    }
    
    function isActiveTeamMember(eventId) {
      return isAuthenticated() && 
             request.auth.token.email != null && 
             exists(/databases/$(database)/documents/events/$(eventId)/team/$(request.auth.token.email)) && 
             get(/databases/$(database)/documents/events/$(eventId)/team/$(request.auth.token.email)).data.status == 'active';
    }

    // Users Collection
    match /users/{userId} {
      // Users can read/write their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
      
      // Notifications Subcollection
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated();
      }
    }

    // Events Collection
    match /events/{eventId} {
      // Anyone can read events
      allow read: if true;
      // Only admins or the event organizer can write events
      allow write: if isAdmin() || (isAuthenticated() && request.resource.data.organizerId == request.auth.uid) || (isAuthenticated() && resource != null && resource.data.organizerId == request.auth.uid);
      
      // TicketTiers Subcollection
      match /ticketTiers/{tierId} {
        allow read: if true;
        allow write: if isAdmin() || isOrganizer(eventId);
        allow update: if isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reserved']); // Only allow modifying reserved count client-side
      }
      
      // Team Subcollection
      match /team/{memberId} {
        allow read: if isAuthenticated();
        // Admins and organizers can manage the team
        allow write: if isAdmin() || isOrganizer(eventId);
        // Users can create/update a request for themselves
        allow create, update: if isAuthenticated() 
                      && request.resource.data.status == 'requested'
                      && request.resource.data.userId == request.auth.uid;
      }
      
      // Reservations Subcollection
      match /reservations/{reservationId} {
        allow read: if isAuthenticated() && (resource == null || request.auth.uid == resource.data.userId || isAdmin());
        allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
        allow update: if isAuthenticated() && isAdmin();
        allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      }
    }

    // Allow collection group queries on reservations
    match /{path=**}/reservations/{reservationId} {
      allow read: if isAuthenticated() && (resource == null || request.auth.uid == resource.data.userId || isAdmin());
    }

    // Allow collection group queries on team
    match /{path=**}/team/{memberId} {
      allow read: if isAuthenticated(); 
    }

    // Tickets Collection
    match /tickets/{ticketId} {
      // Users can read their own tickets. Pending recipients can read. Admins can read all.
      allow read: if isAuthenticated() && (
        resource.data.owner_id == request.auth.uid || 
        (resource.data.transfer_pending_to != null && resource.data.transfer_pending_to == request.auth.token.email) || 
        isAdmin()
      );
      
      // Creating/deleting tickets restricted to admins/owners logic from elsewhere, but keeping it simple:
      allow create, delete: if isAdmin();

      // Updates
      allow update: if isAuthenticated() && (
        // Current owner can update (e.g. set transfer_pending_to)
        resource.data.owner_id == request.auth.uid || 
        // Pending recipient can claim the ticket
        (
          resource.data.transfer_pending_to != null && 
          resource.data.transfer_pending_to == request.auth.token.email &&
          request.resource.data.owner_id == request.auth.uid &&
          request.resource.data.transfer_pending_to == null
        ) || 
        isAdmin()
      );
    }
  }
}
