rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profiles folder
    match /profiles/{userId} {
      // Anyone can read profile images
      allow read: if true;
      
      // Only the authenticated user can upload/edit their own profile image
      // Limit file size to 5MB (5 * 1024 * 1024 bytes)
      // Only allow image content types
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    // Events folder
    match /events/{userId}/{imageId} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }


    // Default deny for everything else (to be safe)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
